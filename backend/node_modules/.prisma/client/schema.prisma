generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DIRECTOR_COMERCIAL
  EJECUTIVO_VENTAS
  MARKETING
}

enum AccountStatus {
  CLIENTE_ACTIVO
  CLIENTE_EN_RIESGO
  PROSPECTO_CALIFICADO
  LEAD_FRIO
  CHURNED
}

enum Industry {
  BANCA
  RETAIL
  TELCO
  FINTECH
  OTRO
}

enum CompanySize {
  ENTERPRISE
  MID_MARKET
  SMB
}

enum ProductType {
  PROCESAMIENTO_PAGOS
  ONBOARDING_DIGITAL
  SEGURIDAD_TRANSACCIONAL
  DISPONIBILIDAD_CONTINUA
}

enum PipelineStage {
  PROSPECCION
  CALIFICACION
  DEMO_PROPUESTA
  NEGOCIACION
  CONTRATO
  CERRADO_GANADO
  CERRADO_PERDIDO
}

enum ContactRole {
  DECISION_MAKER
  INFLUENCIADOR
  USUARIO
  BLOQUEADOR
}

enum ActivityType {
  LLAMADA
  EMAIL
  REUNION
  DEMO
  PROPUESTA_ENVIADA
  CONTRATO_ENVIADO
  NOTA
}

enum LeadSource {
  REFERIDO
  WEB
  EVENTO
  OUTBOUND
  PARTNER
}

enum BANTBudget {
  SI
  NO
  DESCONOCIDO
}

enum BANTAuthority {
  SI
  INFLUENCIADOR
  USUARIO
}

enum BANTNeed {
  ALTA
  MEDIA
  BAJA
}

enum BANTTimeline {
  MENOS_3M
  TRES_A_6M
  SEIS_A_12M
  MAS_12M
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(EJECUTIVO_VENTAS)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities Opportunity[]
  activities    Activity[]
  leads         Lead[]

  @@map("users")
}

model Account {
  id            String        @id @default(cuid())
  razonSocial   String
  rfc           String?       @unique
  industry      Industry
  size          CompanySize
  status        AccountStatus @default(LEAD_FRIO)
  website       String?
  phone         String?
  address       String?
  city          String?
  healthScore   Int           @default(50)
  annualRevenue Float?
  employeeCount Int?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  products      AccountProduct[]

  @@map("accounts")
}

model AccountProduct {
  id         String      @id @default(cuid())
  accountId  String
  product    ProductType
  contracted Boolean     @default(false)
  startDate  DateTime?
  endDate    DateTime?
  value      Float?
  createdAt  DateTime    @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, product])
  @@map("account_products")
}

model Contact {
  id        String      @id @default(cuid())
  accountId String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      ContactRole
  jobTitle  String?
  linkedin  String?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  account      Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activities   Activity[]
  stakeholders OpportunityStakeholder[]

  @@map("contacts")
}

model Opportunity {
  id                String        @id @default(cuid())
  accountId         String
  ownerId           String
  name              String
  stage             PipelineStage @default(PROSPECCION)
  value             Float
  probability       Int           @default(20)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  competitors       String[]
  nextStep          String?
  lossReason        String?
  notes             String?
  daysInStage       Int           @default(0)
  lastStageChange   DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  account      Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner        User                     @relation(fields: [ownerId], references: [id])
  products     OpportunityProduct[]
  activities   Activity[]
  stakeholders OpportunityStakeholder[]
  stageHistory StageHistory[]

  @@map("opportunities")
}

model OpportunityProduct {
  id            String      @id @default(cuid())
  opportunityId String
  product       ProductType
  value         Float?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, product])
  @@map("opportunity_products")
}

model OpportunityStakeholder {
  id            String  @id @default(cuid())
  opportunityId String
  contactId     String
  supportLevel  String // APOYA, NEUTRAL, BLOQUEA
  notes         String?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, contactId])
  @@map("opportunity_stakeholders")
}

model StageHistory {
  id              String         @id @default(cuid())
  opportunityId   String
  fromStage       PipelineStage?
  toStage         PipelineStage
  changedAt       DateTime       @default(now())
  reason          String?
  daysInPrevStage Int?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("stage_history")
}

model Lead {
  id            String        @id @default(cuid())
  ownerId       String
  companyName   String
  contactName   String
  email         String?
  phone         String?
  industry      Industry?
  source        LeadSource
  bantBudget    BANTBudget    @default(DESCONOCIDO)
  bantAuthority BANTAuthority @default(USUARIO)
  bantNeed      BANTNeed      @default(BAJA)
  bantTimeline  BANTTimeline  @default(MAS_12M)
  score         Int           @default(0)
  notes         String?
  converted     Boolean       @default(false)
  convertedAt   DateTime?
  accountId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  @@map("leads")
}

model Activity {
  id            String       @id @default(cuid())
  userId        String
  accountId     String?
  opportunityId String?
  contactId     String?
  type          ActivityType
  title         String
  description   String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  duration      Int?
  outcome       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@map("activities")
}
